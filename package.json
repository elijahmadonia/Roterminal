{
  "name": "roterminal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:worker\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "ROTERMINAL_SERVER_ENABLE_SCHEDULED_INGEST=false node --env-file-if-exists=.env server/index.mjs",
    "dev:worker": "node --env-file-if-exists=.env server/worker.mjs",
    "build": "tsc -b && vite build",
    "build:client": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "import:history": "node server/scripts/import-external-history.mjs",
    "sync:tracked": "node server/scripts/sync-tracked-universes.mjs",
    "start": "concurrently --kill-others-on-fail \"npm:start:api\" \"npm:start:worker\"",
    "start:api": "ROTERMINAL_SERVER_ENABLE_SCHEDULED_INGEST=false node --env-file-if-exists=.env server/index.mjs",
    "start:server": "node --env-file-if-exists=.env server/index.mjs",
    "start:worker": "node --env-file-if-exists=.env server/worker.mjs"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@number-flow/react": "^0.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "geist": "^1.7.0",
    "liveline": "^0.0.7",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
